<!doctype html>
<html lang="it">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>Aggiornamento Banking · {{ generated_at | fmt_date_short }}</title>
<meta name="description" content="Intelligence settimanale sulle banche italiane. Risultati, comunicati, interviste CEO, operazioni straordinarie e tematiche fiscali. Aggiornamento del {{ generated_at | fmt_date_short }}.">
<meta name="robots" content="noindex,nofollow">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,ital,wght@9..144,0,400;9..144,0,500;9..144,0,600;9..144,0,700;9..144,1,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#faf9f5; --paper:#ffffff; --ink:#1f1e1c; --ink-soft:#3d3a35; --muted:#6b675e;
    --line:#e8e4d8; --line-soft:#f1ede1; --accent:#cc785c; --accent-deep:#a85a40; --accent-soft:#f4e4dc;
    --warm:#f5f1e6; --warm-deeper:#ede6d3;
    --gold:#c8a951; --gold-soft:#fbf4dc;
    --green:#5a8f6b; --green-soft:#e4ede2;
    --blue:#5a7a9f; --blue-soft:#e1e8ef;
    --plum:#8d4f7d; --plum-soft:#f0e2ec;
    --shadow-sm:0 1px 2px rgba(31,30,28,.04);
    --shadow-md:0 4px 16px -4px rgba(31,30,28,.08), 0 1px 3px rgba(31,30,28,.04);
    --shadow-lg:0 24px 60px -20px rgba(31,30,28,.18), 0 6px 14px rgba(31,30,28,.05);
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--ink);
    font-family:'Inter',-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
    font-size:15.5px;line-height:1.62;-webkit-font-smoothing:antialiased}
  .serif{font-family:'Fraunces',Georgia,serif;font-weight:500;letter-spacing:-.01em}
  .mono{font-family:'JetBrains Mono',ui-monospace,monospace}
  a{color:var(--accent-deep);text-decoration:none;border-bottom:1px solid transparent;transition:border-color .15s}
  a:hover{border-bottom-color:var(--accent)}

  nav.top{position:sticky;top:0;z-index:30;backdrop-filter:saturate(1.2) blur(10px);
    background:rgba(250,249,245,.86);border-bottom:1px solid var(--line)}
  nav.top .wrap{max-width:1280px;margin:0 auto;padding:14px 22px;
    display:flex;align-items:center;justify-content:space-between;gap:18px}
  nav.top .brand{display:flex;align-items:center;gap:10px;font-weight:600;font-size:13.5px;color:var(--ink)}
  nav.top .brand .dot{width:10px;height:10px;border-radius:50%;
    background:radial-gradient(circle at 30% 30%,#f0a98e,var(--accent-deep))}
  nav.top .brand small{display:block;font-weight:400;font-size:11px;color:var(--muted);letter-spacing:.04em}
  nav.top ul{display:flex;list-style:none;margin:0;padding:0;gap:22px}
  nav.top a{font-size:13px;color:var(--ink-soft);font-weight:500;border:none}
  nav.top a:hover{color:var(--accent-deep)}
  @media (max-width:680px){nav.top ul{display:none}}

  .hero{position:relative;overflow:hidden;
    background:radial-gradient(900px 500px at 85% -10%, rgba(90,143,107,.14), transparent 60%),
      radial-gradient(700px 400px at -10% 110%, rgba(200,169,81,.18), transparent 60%),
      linear-gradient(180deg,#fdfcf7 0%,#faf9f5 100%);
    border-bottom:1px solid var(--line)}
  .hero .wrap{max-width:1280px;margin:0 auto;padding:46px 22px 40px;display:grid;grid-template-columns:1.4fr .9fr;gap:40px;align-items:end}
  @media (max-width:900px){.hero .wrap{grid-template-columns:1fr;gap:18px;padding:34px 22px 28px}}
  .eyebrow{display:inline-flex;align-items:center;gap:10px;font-size:11.5px;
    text-transform:uppercase;letter-spacing:.18em;color:var(--accent-deep);font-weight:700;
    background:var(--accent-soft);padding:6px 12px 6px 10px;border-radius:999px;margin-bottom:16px}
  .eyebrow::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--accent)}
  .hero h1{font-family:'Fraunces',Georgia,serif;font-weight:500;
    font-size:clamp(34px,5vw,58px);line-height:1.04;letter-spacing:-.022em;margin:0 0 12px;color:var(--ink)}
  .hero h1 em{font-style:italic;color:var(--accent);font-weight:500}
  .hero .lead{font-size:16.5px;color:var(--ink-soft);line-height:1.62;max-width:60ch;margin:0}
  .stats-row{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
  @media (max-width:560px){.stats-row{grid-template-columns:repeat(2,1fr);gap:8px}}
  .stat{background:var(--paper);border:1px solid var(--line);border-radius:14px;padding:14px 16px}
  .stat .n{font-family:'Fraunces',serif;font-weight:500;font-size:24px;color:var(--accent-deep);letter-spacing:-.02em;line-height:1;display:block}
  .stat .lbl{font-size:10.5px;text-transform:uppercase;letter-spacing:.14em;color:var(--muted);font-weight:700;margin-top:6px;display:block}

  main{max-width:1280px;margin:0 auto;padding:32px 22px 24px;display:grid;grid-template-columns:280px 1fr;gap:30px;align-items:start}
  @media (max-width:980px){main{grid-template-columns:1fr;gap:18px;padding:20px 16px 24px}}

  aside.filters{position:sticky;top:74px;background:var(--paper);border:1px solid var(--line);
    border-radius:18px;padding:20px 18px;box-shadow:var(--shadow-sm);max-height:calc(100vh - 100px);overflow-y:auto}
  aside.filters h3{font-family:'Fraunces',serif;font-weight:500;font-size:16px;margin:0 0 12px;letter-spacing:-.01em;color:var(--ink);
    display:flex;justify-content:space-between;align-items:center;gap:8px}
  aside.filters h3 .actions{display:flex;gap:10px;align-items:center}
  aside.filters h3 button.reset{font-size:11px;color:var(--accent-deep);background:none;border:none;cursor:pointer;font-weight:700;letter-spacing:.04em;text-transform:uppercase;padding:4px 6px;border-radius:6px}
  aside.filters h3 button.reset:hover{background:var(--accent-soft)}
  aside.filters .close-drawer{display:none;background:var(--warm);border:1px solid var(--line);border-radius:10px;
    width:36px;height:36px;align-items:center;justify-content:center;cursor:pointer;font-size:18px;color:var(--ink-soft);padding:0}

  .fgroup{margin-bottom:16px;padding-bottom:14px;border-bottom:1px dashed var(--line-soft)}
  .fgroup:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
  .fgroup .glbl{font-size:10.5px;text-transform:uppercase;letter-spacing:.16em;color:var(--muted);font-weight:700;margin-bottom:8px;display:block}
  .fopt{display:flex;align-items:center;gap:8px;padding:7px 0;font-size:13.5px;color:var(--ink-soft);cursor:pointer;user-select:none;min-height:30px}
  .fopt input{margin:0;accent-color:var(--accent-deep);width:16px;height:16px;flex-shrink:0}
  .fopt .n{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted)}
  .fopt:hover{color:var(--ink)}
  .swatch{width:9px;height:9px;border-radius:50%;display:inline-block;flex-shrink:0}
  .swatch.risultati{background:var(--green)}
  .swatch.comunicato{background:var(--blue)}
  .swatch.intervista-ceo{background:var(--gold)}
  .swatch.operazione-straordinaria{background:var(--accent)}
  .swatch.fisco{background:var(--plum)}

  .periodo-presets{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px}
  .ppill{font-size:11.5px;padding:5px 10px;border-radius:999px;background:var(--warm);color:var(--ink-soft);
    font-weight:600;border:1px solid var(--line);cursor:pointer;transition:all .15s;font-family:inherit;line-height:1.1}
  .ppill:hover{border-color:var(--accent)}
  .ppill.on{background:var(--accent-deep);color:#fdfcf7;border-color:var(--accent-deep)}
  .periodo-slider{padding:4px 2px 0}
  .periodo-slider input[type="range"]{width:100%;accent-color:var(--accent-deep);margin:6px 0 4px;height:22px;cursor:pointer}
  .periodo-label{font-size:11.5px;color:var(--muted);line-height:1.4;display:flex;justify-content:space-between;gap:8px;flex-wrap:wrap}
  .periodo-label b{font-family:'Fraunces',serif;font-weight:500;color:var(--ink);font-size:13px}
  .periodo-label .ft{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--muted)}

  .clisearch{display:flex;align-items:center;gap:6px;background:var(--warm);border:1px solid var(--line);
    border-radius:10px;padding:6px 10px;margin-bottom:6px}
  .clisearch::before{content:"⌕";color:var(--muted);font-size:14px;line-height:1}
  .clisearch input{border:none;background:transparent;outline:none;font-size:13px;width:100%;color:var(--ink);font-family:inherit}
  .clisearch input::placeholder{color:var(--muted)}

  details.fascia{margin-top:8px;border-radius:10px;background:var(--warm);border:1px solid var(--line-soft);padding:6px 10px 8px}
  details.fascia[open]{padding-bottom:10px}
  details.fascia > summary{cursor:pointer;font-size:11.5px;text-transform:uppercase;letter-spacing:.12em;color:var(--ink-soft);
    font-weight:700;padding:6px 0;display:flex;align-items:center;gap:8px;list-style:none;outline:none}
  details.fascia > summary::-webkit-details-marker{display:none}
  details.fascia > summary::before{content:"▸";color:var(--muted);font-size:10px;transition:transform .12s ease;display:inline-block}
  details.fascia[open] > summary::before{transform:rotate(90deg)}
  details.fascia > summary .badge-mini{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--muted);font-weight:600}
  details.fascia .fopt{padding:5px 0;font-size:13px;min-height:26px}

  .filter-fab{display:none}
  .filter-backdrop{display:none}

  @media (max-width:980px){
    aside.filters{position:fixed;top:0;left:0;right:0;bottom:0;border-radius:0;max-height:100vh;
      transform:translateX(-100%);transition:transform .26s ease;z-index:60;padding:18px 18px 100px;border:none;border-right:1px solid var(--line)}
    aside.filters.open{transform:translateX(0);box-shadow:var(--shadow-lg)}
    aside.filters .close-drawer{display:inline-flex}
    .filter-backdrop{display:block;position:fixed;inset:0;background:rgba(31,30,28,.42);
      opacity:0;pointer-events:none;transition:opacity .22s ease;z-index:55}
    .filter-backdrop.on{opacity:1;pointer-events:auto}
    .filter-fab{display:inline-flex;position:fixed;bottom:18px;left:50%;transform:translateX(-50%);
      z-index:50;background:var(--ink);color:#fdfcf7;border:none;border-radius:999px;
      padding:13px 22px;font-size:14px;font-weight:600;align-items:center;gap:10px;
      box-shadow:0 10px 30px -8px rgba(31,30,28,.4), 0 4px 12px rgba(31,30,28,.18);cursor:pointer}
    .filter-fab .ico{display:inline-flex;width:18px;height:18px;align-items:center;justify-content:center}
    .filter-fab .count{background:var(--accent);color:#fdfcf7;font-family:'JetBrains Mono',monospace;
      font-size:11px;font-weight:700;border-radius:999px;padding:2px 8px;min-width:22px;text-align:center;display:none}
    .filter-fab .count.on{display:inline-block}
  }
  @media (max-width:540px){
    .filter-fab{left:16px;right:16px;transform:none;justify-content:center}
  }

  .content{display:flex;flex-direction:column;gap:30px;min-width:0}
  .client{scroll-margin-top:90px}
  .client-head{background:var(--paper);border:1px solid var(--line);border-radius:18px;
    padding:22px 26px;box-shadow:var(--shadow-sm);margin-bottom:18px;
    display:grid;grid-template-columns:1fr auto;gap:18px;align-items:center}
  @media (max-width:680px){.client-head{grid-template-columns:1fr;padding:18px 20px}}
  .client-head .left{display:flex;align-items:center;gap:14px;flex-wrap:wrap}
  .client-head .name{font-family:'Fraunces',serif;font-weight:500;font-size:30px;
    letter-spacing:-.018em;margin:0;color:var(--ink)}
  @media (max-width:560px){.client-head .name{font-size:24px}}
  .badge{font-size:10.5px;text-transform:uppercase;letter-spacing:.14em;font-weight:700;
    padding:5px 12px;border-radius:999px;background:var(--warm);color:var(--ink-soft);border:1px solid var(--line)}
  .badge.top10{background:var(--accent-soft);color:var(--accent-deep);border-color:#f0d4c5}
  .badge.media{background:var(--gold-soft);color:#7a6320;border-color:#e6d390}
  .badge.piccola{background:var(--green-soft);color:#3e6a4d;border-color:#bcd4c2}
  .audit-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px 18px;font-size:12px;color:var(--muted)}
  @media (max-width:560px){.audit-grid{grid-template-columns:1fr 1fr;gap:6px 12px}}
  .audit-grid .a{display:flex;flex-direction:column}
  .audit-grid .a .lbl{font-size:10px;text-transform:uppercase;letter-spacing:.14em;color:var(--muted);font-weight:700}
  .audit-grid .a .val{font-family:'Fraunces',serif;font-weight:500;font-size:14px;color:var(--ink-soft);margin-top:2px}

  .grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
  @media (max-width:980px){.grid{grid-template-columns:repeat(2,1fr)}}
  @media (max-width:780px){.grid{grid-template-columns:1fr}}
  article.card{background:var(--paper);border:1px solid var(--line);border-radius:16px;
    padding:22px 24px;box-shadow:var(--shadow-sm);display:flex;flex-direction:column;gap:10px;
    position:relative;overflow:hidden;transition:transform .12s ease, box-shadow .15s}
  @media (max-width:560px){article.card{padding:18px 20px}}
  article.card:hover{transform:translateY(-2px);box-shadow:var(--shadow-md)}
  article.card::before{content:"";position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--line)}
  article.card[data-tipo="risultati"]::before{background:var(--green)}
  article.card[data-tipo="comunicato"]::before{background:var(--blue)}
  article.card[data-tipo="intervista-ceo"]::before{background:var(--gold)}
  article.card[data-tipo="operazione-straordinaria"]::before{background:var(--accent)}
  article.card[data-tipo="fisco"]::before{background:var(--plum)}
  article.card .meta-row{display:flex;align-items:center;gap:8px;font-size:11px;color:var(--muted);
    text-transform:uppercase;letter-spacing:.1em;font-weight:600;flex-wrap:wrap}
  article.card .meta-row time{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--accent-deep)}
  article.card .meta-row .src{color:var(--ink-soft)}
  article.card .meta-row .dotsep{width:3px;height:3px;border-radius:50%;background:var(--line);display:inline-block;flex-shrink:0}
  .client-pill{display:inline-flex;align-items:center;gap:6px;font-size:11px;padding:3px 9px 3px 7px;
    border-radius:999px;font-weight:700;letter-spacing:.04em;text-transform:none;
    background:var(--warm);color:var(--ink-soft);border:1px solid var(--line);max-width:100%}
  .client-pill::before{content:"";width:6px;height:6px;border-radius:50%;flex-shrink:0;background:var(--muted)}
  .client-pill.f-top10{background:var(--accent-soft);color:var(--accent-deep);border-color:#f0d4c5}
  .client-pill.f-top10::before{background:var(--accent)}
  .client-pill.f-media{background:var(--gold-soft);color:#7a6320;border-color:#e6d390}
  .client-pill.f-media::before{background:var(--gold)}
  .client-pill.f-piccola{background:var(--green-soft);color:#3e6a4d;border-color:#bcd4c2}
  .client-pill.f-piccola::before{background:var(--green)}

  article.card h3{font-family:'Fraunces',serif;font-weight:500;font-size:20px;line-height:1.24;
    letter-spacing:-.012em;margin:4px 0 0;color:var(--ink)}
  @media (max-width:560px){article.card h3{font-size:18px}}
  article.card p.sum{font-size:14px;color:var(--ink-soft);line-height:1.58;margin:0}
  article.card .detail{font-size:12.5px;color:var(--muted);line-height:1.55;margin:0;padding:10px 12px;
    background:var(--warm);border-radius:8px;border-left:2px solid var(--line)}
  article.card .audit-alert{font-size:11px;font-weight:700;letter-spacing:.06em;color:#a85a40;
    background:var(--gold-soft);border:1px solid #e6d390;border-radius:8px;padding:6px 10px;text-transform:uppercase}
  article.card .foot{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-top:auto;padding-top:6px;flex-wrap:wrap}
  article.card .foot a.read{font-size:12.5px;font-weight:600;color:var(--accent-deep);border:none}
  .tag{font-size:10.5px;padding:4px 10px;border-radius:999px;font-weight:700;
    text-transform:uppercase;letter-spacing:.08em;border:1px solid;flex-shrink:0}
  .tag.t-risultati{background:var(--green-soft);color:#3e6a4d;border-color:#bcd4c2}
  .tag.t-comunicato{background:var(--blue-soft);color:#3d5874;border-color:#bccad8}
  .tag.t-intervista-ceo{background:var(--gold-soft);color:#7a6320;border-color:#e6d390}
  .tag.t-operazione-straordinaria{background:var(--accent-soft);color:var(--accent-deep);border-color:#f0d4c5}
  .tag.t-fisco{background:var(--plum-soft);color:var(--plum);border-color:#dcc1d4}

  .empty{padding:40px 22px;text-align:center;color:var(--muted);font-size:14px;
    background:var(--paper);border:1px dashed var(--line);border-radius:14px}

  footer{padding:36px 22px 60px;text-align:center;color:var(--muted);font-size:12.5px;
    border-top:1px solid var(--line);margin-top:30px;background:#fdfcf7}
  footer .row{max-width:1280px;margin:0 auto;display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px}
  footer a{color:var(--ink-soft)}
</style>
</head>
<body>

<nav class="top">
  <div class="wrap">
    <div class="brand">
      <span class="dot" aria-hidden="true"></span>
      <div>Aggiornamento Banking<br><small>Aggiornato {{ generated_at | fmt_date_long }}</small></div>
    </div>
    <ul>
      <li><a href="index.html">← Home</a></li>
      {% for s in sections %}<li><a href="#{{ s.slug }}">{{ s.nome.split()[0] }}</a></li>{% endfor %}
    </ul>
  </div>
</nav>

<header class="hero">
  <div class="wrap">
    <div>
      <span class="eyebrow">Aggiornato {{ generated_at | fmt_date_long }} · prossimo update {{ next_update | fmt_date_long }}</span>
      <h1>Intelligence settimanale sulle <em>banche italiane</em></h1>
      <p class="lead">Bilanci, comunicati ufficiali, interviste e dichiarazioni dei CEO, operazioni straordinarie e tematiche fiscali emergenti — sintetizzati automaticamente dalle fonti pubbliche.</p>
    </div>
    <div class="stats-row">
      <div class="stat"><span class="n">{{ n_items }}</span><span class="lbl">news raccolte</span></div>
      <div class="stat"><span class="n">{{ n_fonti }}</span><span class="lbl">fonti consultate</span></div>
      <div class="stat"><span class="n">{{ n_banche_monitorate }}</span><span class="lbl">banche monitorate</span></div>
      <div class="stat"><span class="n">{{ n_clienti_con_news }}</span><span class="lbl">con news questa sett.</span></div>
    </div>
  </div>
</header>

<div class="filter-backdrop" id="filterBackdrop"></div>

<main>

  <aside class="filters" id="filtersPanel" aria-label="Filtri">
    <h3>
      Filtri
      <span class="actions">
        <button type="button" class="reset" id="resetBtn">Azzera</button>
        <button type="button" class="close-drawer" id="closeDrawer" aria-label="Chiudi filtri">✕</button>
      </span>
    </h3>

    <div class="fgroup">
      <span class="glbl">Periodo di pubblicazione</span>
      <div class="periodo-presets" role="group" aria-label="Preset periodo">
        <button type="button" class="ppill" data-days="7">7 gg</button>
        <button type="button" class="ppill" data-days="30">30 gg</button>
        <button type="button" class="ppill" data-days="90">3 mesi</button>
        <button type="button" class="ppill" data-days="180">6 mesi</button>
        <button type="button" class="ppill on" data-days="365">Tutto</button>
      </div>
      <div class="periodo-slider">
        <input type="range" id="dateRange" min="7" max="365" step="1" value="365" aria-label="Ultimi N giorni">
        <div class="periodo-label">
          <span>Ultimi <b id="dateRangeLabel">90</b> giorni</span>
          <span class="ft" id="dateRangeFromTo">dal —</span>
        </div>
      </div>
    </div>

    <div class="fgroup">
      <span class="glbl">Tipologia notizia</span>
      {% for slug, label in [('risultati','Risultati economici'),('comunicato','Comunicati stampa'),('intervista-ceo','Interviste / dich. CEO'),('operazione-straordinaria','Operazioni straord.'),('fisco','Tematiche fiscali')] %}
      <label class="fopt"><input type="checkbox" data-filter="tipo" data-val="{{ slug }}"> <span class="swatch {{ slug }}"></span> {{ label }} <span class="n">{{ counters.tipo.get(slug, 0) }}</span></label>
      {% endfor %}
    </div>

    <div class="fgroup">
      <span class="glbl">Fascia clientela</span>
      {% for slug, label in [('top10','Top 10 gruppi'),('media','Banche medie'),('piccola','Piccole / fintech')] %}
      <label class="fopt"><input type="checkbox" data-filter="fascia" data-val="{{ slug }}"> {{ label }} <span class="n">{{ counters.fascia.get(slug, 0) }}</span></label>
      {% endfor %}
    </div>

    <div class="fgroup">
      <span class="glbl">Cliente ({{ n_banche_monitorate }} banche)</span>
      <div class="clisearch"><input type="search" id="clisearch" placeholder="Cerca banca…" autocomplete="off"></div>
      {% for fkey, flabel in [('top10','Top 10 gruppi'),('media','Banche medie / regionali'),('piccola','Piccole / fintech / specializzate')] %}
      <details class="fascia" open>
        <summary>{{ flabel }} <span class="badge-mini">{{ by_fascia[fkey] | length }}</span></summary>
        {% for c in by_fascia[fkey] %}
        <label class="fopt"><input type="checkbox" data-filter="cliente" data-val="{{ c.slug }}"> {{ c.nome }} <span class="n">{{ counters.cliente.get(c.slug, 0) }}</span></label>
        {% endfor %}
      </details>
      {% endfor %}
    </div>

    <div class="fgroup">
      <span class="glbl">Emittente notizia</span>
      {% for slug, label in [('sole24','Il Sole 24 Ore'),('ansa','ANSA'),('mf','MF Milano Finanza'),('bloomberg','Bloomberg'),('reuters','Reuters'),('corporate','Corporate press'),('bebeez','BeBeez'),('eutekne','Eutekne'),('fiscooggi','FiscoOggi'),('bancaditalia',"Banca d'Italia"),('consob','Consob'),('mef','MEF')] %}
      <label class="fopt"><input type="checkbox" data-filter="emittente" data-val="{{ slug }}"> {{ label }} {% if counters.emittente.get(slug, 0) > 0 %}<span class="n">{{ counters.emittente.get(slug, 0) }}</span>{% endif %}</label>
      {% endfor %}
    </div>
  </aside>

  <div class="content">
    {% for s in sections %}
    <section class="client" id="{{ s.slug }}">
      <div class="client-head">
        <div class="left">
          <h2 class="name">{{ s.nome }}</h2>
          <span class="badge {{ s.fascia }}">{% if s.fascia == 'top10' %}Top 10 gruppi{% elif s.fascia == 'media' %}Banca media{% else %}Piccola / fintech{% endif %}</span>
        </div>
        <div class="audit-grid">
          <div class="a"><span class="lbl">Revisore</span><span class="val">{{ s.revisore or '—' }}</span></div>
          <div class="a"><span class="lbl">Ult. esercizio</span><span class="val">{% if s.ultimo_esercizio_revisionato %}{{ s.ultimo_esercizio_revisionato }}{% if s.incarico_fino_al %} · incarico al {{ s.incarico_fino_al }}{% endif %}{% else %}—{% endif %}</span></div>
          <div class="a"><span class="lbl">AD</span><span class="val">{{ s.ad or '—' }}</span></div>
          <div class="a"><span class="lbl">Presidente</span><span class="val">{{ s.presidente or '—' }}</span></div>
        </div>
      </div>
      <div class="grid">
        {% for item in s.news %}
        <article class="card" data-cliente="{{ s.slug }}" data-fascia="{{ s.fascia }}" data-emittente="{{ item.emittente_slug }}" data-tipo="{{ item.tipo }}" data-date="{{ item.data }}">
          <div class="meta-row">
            <span class="client-pill f-{{ s.fascia }}">{{ s.nome }}</span>
            <time>{{ item.data | fmt_date_short }}</time><span class="dotsep"></span><span class="src">{{ item.emittente_label }}</span>
          </div>
          <h3>{{ item.titolo }}</h3>
          <p class="sum">{{ item.sintesi }}</p>
          {% if item.dettaglio %}<p class="detail">{{ item.dettaglio }}</p>{% endif %}
          {% if item.audit_alert %}<p class="audit-alert">⚠ Audit alert: possibile variazione incarico di revisione</p>{% endif %}
          <div class="foot">
            <span class="tag t-{{ item.tipo }}">{% if item.tipo == 'risultati' %}Risultati{% elif item.tipo == 'comunicato' %}Comunicato{% elif item.tipo == 'intervista-ceo' %}Intervista CEO{% elif item.tipo == 'operazione-straordinaria' %}Operazione straord.{% elif item.tipo == 'fisco' %}Fisco{% else %}{{ item.tipo }}{% endif %}</span>
            {% if item.url %}<a class="read" href="{{ item.url }}" target="_blank" rel="noopener">leggi la fonte →</a>{% endif %}
          </div>
        </article>
        {% endfor %}
      </div>
    </section>
    {% else %}
    <div class="empty">Nessuna news raccolta in questo run.</div>
    {% endfor %}
    <div class="empty" id="emptyState" style="display:none">Nessuna news corrisponde ai filtri selezionati. <a href="#" id="emptyReset">Azzera filtri</a>.</div>
  </div>

</main>

<button class="filter-fab" id="filterFab" type="button" aria-label="Apri filtri">
  <span class="ico" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
      <path d="M2 3.5h12M4 8h8M6 12.5h4"/>
    </svg>
  </span>
  <span>Filtri</span>
  <span class="count" id="filterCount">0</span>
</button>

<footer>
  <div class="row">
    <span>Aggiornamento Banking · generato {{ generated_at | fmt_date_long }}</span>
    <span>Sintesi assistita da AI · <a href="index.html">torna all'area riservata</a></span>
  </div>
  <p style="max-width:720px;margin:14px auto 0;font-size:11.5px;color:var(--muted);line-height:1.55">
    Contenuti generati automaticamente da fonti pubbliche linkate. Le sintesi sono prodotte da un modello linguistico (Claude Sonnet); verifica sempre le fonti originali prima di citare. Anteprima pre-pubblicazione disponibile su Pull Request — solo dopo il merge la pagina diventa pubblica.
  </p>
</footer>

<script>
(function(){
  var active = { cliente:[], fascia:[], emittente:[], tipo:[] };
  var TODAY = new Date({{ generated_at.year }}, {{ generated_at.month - 1 }}, {{ generated_at.day }});
  var maxDays = 365;

  var checks = document.querySelectorAll('input[type="checkbox"][data-filter]');
  var panel = document.getElementById('filtersPanel');
  var backdrop = document.getElementById('filterBackdrop');
  var fab = document.getElementById('filterFab');
  var fabCount = document.getElementById('filterCount');
  var closeBtn = document.getElementById('closeDrawer');
  var resetBtn = document.getElementById('resetBtn');
  var search = document.getElementById('clisearch');
  var dateRange = document.getElementById('dateRange');
  var dateRangeLabel = document.getElementById('dateRangeLabel');
  var dateRangeFromTo = document.getElementById('dateRangeFromTo');
  var presets = document.querySelectorAll('.ppill');

  var MM_IT = ['gen','feb','mar','apr','mag','giu','lug','ago','set','ott','nov','dic'];
  function fmtIt(d){ return d.getDate() + ' ' + MM_IT[d.getMonth()] + ' ' + d.getFullYear(); }
  function parseISO(s){ var p = s.split('-'); return new Date(parseInt(p[0],10), parseInt(p[1],10)-1, parseInt(p[2],10)); }

  function updateDateUI(days){
    if(days >= 365){
      dateRangeLabel.textContent = '∞';
      dateRangeFromTo.textContent = 'tutte le news';
    } else {
      dateRangeLabel.textContent = days;
      var from = new Date(TODAY); from.setDate(from.getDate() - days);
      dateRangeFromTo.textContent = 'dal ' + fmtIt(from);
    }
    presets.forEach(function(p){ p.classList.toggle('on', parseInt(p.dataset.days,10) === days); });
  }

  if(dateRange){
    dateRange.addEventListener('input', function(){
      maxDays = parseInt(this.value, 10);
      updateDateUI(maxDays);
      apply();
    });
  }

  presets.forEach(function(p){
    p.addEventListener('click', function(){
      maxDays = parseInt(p.dataset.days, 10);
      if(dateRange) dateRange.value = maxDays;
      updateDateUI(maxDays);
      apply();
    });
  });

  checks.forEach(function(c){
    c.addEventListener('change', function(){
      var f = c.dataset.filter, v = c.dataset.val;
      var i = active[f].indexOf(v);
      if(c.checked && i<0) active[f].push(v);
      else if(!c.checked && i>=0) active[f].splice(i,1);
      apply();
    });
  });

  if(resetBtn) resetBtn.addEventListener('click', reset);
  var er = document.getElementById('emptyReset'); if(er) er.addEventListener('click', function(e){e.preventDefault(); reset();});

  if(fab) fab.addEventListener('click', openDrawer);
  if(closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if(backdrop) backdrop.addEventListener('click', closeDrawer);

  function openDrawer(){ panel.classList.add('open'); backdrop.classList.add('on'); document.body.style.overflow='hidden'; }
  function closeDrawer(){ panel.classList.remove('open'); backdrop.classList.remove('on'); document.body.style.overflow=''; }

  document.querySelectorAll('article.card a.read').forEach(function(a){
    a.addEventListener('click', function(){ if(window.innerWidth<=980) closeDrawer(); });
  });

  if(search){
    search.addEventListener('input', function(){
      var q = search.value.trim().toLowerCase();
      document.querySelectorAll('details.fascia .fopt').forEach(function(opt){
        var label = opt.textContent.trim().toLowerCase();
        opt.style.display = (q==='' || label.indexOf(q)>=0) ? '' : 'none';
      });
      if(q!==''){ document.querySelectorAll('details.fascia').forEach(function(d){ d.open = true; }); }
    });
  }

  function reset(){
    Object.keys(active).forEach(function(k){ active[k]=[]; });
    checks.forEach(function(c){ c.checked=false; });
    if(search){ search.value=''; document.querySelectorAll('details.fascia .fopt').forEach(function(o){o.style.display='';}); }
    maxDays = 365; if(dateRange){ dateRange.value = 365; } updateDateUI(365);
    apply();
  }

  function apply(){
    var cards = document.querySelectorAll('article.card');
    var visible = 0;
    cards.forEach(function(c){
      var ok = true;
      Object.keys(active).forEach(function(k){
        if(active[k].length && active[k].indexOf(c.dataset[k]) < 0) ok = false;
      });
      if(ok && maxDays < 365 && c.dataset.date){
        var d = parseISO(c.dataset.date);
        var ageDays = Math.floor((TODAY - d) / 86400000);
        if(ageDays > maxDays) ok = false;
      }
      c.style.display = ok ? '' : 'none';
      if(ok) visible++;
    });
    document.querySelectorAll('section.client').forEach(function(s){
      var any = s.querySelectorAll('article.card:not([style*="display: none"])').length;
      s.style.display = any ? '' : 'none';
    });
    var emptyState = document.getElementById('emptyState');
    if(emptyState) emptyState.style.display = visible ? 'none' : '';

    var total = active.cliente.length + active.fascia.length + active.emittente.length + active.tipo.length;
    if(maxDays < 365) total++;
    if(fabCount){ fabCount.textContent = total; fabCount.classList.toggle('on', total>0); }
  }

  updateDateUI(365);
  apply();
})();
</script>

</body>
</html>
