<!doctype html>
<html lang="it">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>News banche · aggiornamento {{ generated_at | fmt_date_short }}</title>
<meta name="description" content="Intelligence settimanale sulle banche italiane. Notizie in ordine cronologico decrescente, anagrafica banca disponibile al click sul nome.">
<meta name="robots" content="noindex,nofollow">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,ital,wght@9..144,0,400;9..144,0,500;9..144,0,600;9..144,0,700;9..144,1,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#faf9f5; --paper:#ffffff; --ink:#1f1e1c; --ink-soft:#3d3a35; --muted:#6b675e;
    --line:#e8e4d8; --line-soft:#f1ede1;
    --accent:#cc785c; --accent-deep:#a85a40; --accent-soft:#f4e4dc;
    --warm:#f5f1e6; --warm-deeper:#ede6d3;
    --gold:#c8a951; --gold-soft:#fbf4dc;
    --green:#5a8f6b; --green-soft:#e4ede2;
    --blue:#5a7a9f; --blue-soft:#e1e8ef;
    --plum:#8d4f7d; --plum-soft:#f0e2ec;
    --shadow-sm:0 1px 2px rgba(31,30,28,.04);
    --shadow-md:0 4px 16px -4px rgba(31,30,28,.08), 0 1px 3px rgba(31,30,28,.04);
    --shadow-lg:0 24px 60px -20px rgba(31,30,28,.18), 0 6px 14px rgba(31,30,28,.05);
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--ink);
    font-family:'Inter',-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
    font-size:15.5px;line-height:1.62;-webkit-font-smoothing:antialiased}
  .mono{font-family:'JetBrains Mono',ui-monospace,monospace}
  a{color:var(--accent-deep);text-decoration:none}
  a:hover{color:var(--accent)}
  button{font-family:inherit}

  /* NAV */
  nav.top{position:sticky;top:0;z-index:30;backdrop-filter:saturate(1.2) blur(10px);
    background:rgba(250,249,245,.9);border-bottom:1px solid var(--line)}
  nav.top .wrap{max-width:1280px;margin:0 auto;padding:12px 20px;
    display:flex;align-items:center;justify-content:space-between;gap:16px}
  nav.top .brand{display:flex;align-items:center;gap:10px;font-weight:600;font-size:13.5px;color:var(--ink);min-width:0}
  nav.top .brand .dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;
    background:radial-gradient(circle at 30% 30%,#f0a98e,var(--accent-deep))}
  nav.top .brand small{display:block;font-weight:400;font-size:11px;color:var(--muted);letter-spacing:.04em}
  nav.top ul{display:flex;list-style:none;margin:0;padding:0;gap:20px}
  nav.top a{font-size:13px;color:var(--ink-soft);font-weight:500}
  nav.top a:hover{color:var(--accent-deep)}
  @media (max-width:680px){nav.top ul{display:none}}

  /* HERO */
  .hero{background:radial-gradient(900px 500px at 85% -10%, rgba(90,143,107,.12), transparent 60%),
    radial-gradient(700px 400px at -10% 110%, rgba(200,169,81,.16), transparent 60%),
    linear-gradient(180deg,#fdfcf7 0%,#faf9f5 100%);border-bottom:1px solid var(--line)}
  .hero .wrap{max-width:1280px;margin:0 auto;padding:32px 20px 26px}
  .eyebrow{display:inline-flex;align-items:center;gap:10px;font-size:11px;text-transform:uppercase;
    letter-spacing:.16em;color:var(--accent-deep);font-weight:700;background:var(--accent-soft);
    padding:5px 12px 5px 10px;border-radius:999px;margin-bottom:12px}
  .eyebrow::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--accent)}
  .hero h1{font-family:'Fraunces',Georgia,serif;font-weight:500;font-size:clamp(28px,4.4vw,44px);
    line-height:1.05;letter-spacing:-.022em;margin:0 0 10px;color:var(--ink)}
  .hero h1 em{font-style:italic;color:var(--accent);font-weight:500}
  .hero .lead{font-size:15.5px;color:var(--ink-soft);line-height:1.55;max-width:64ch;margin:0 0 16px}
  .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
  @media (max-width:680px){.stats-row{grid-template-columns:repeat(2,1fr)}}
  .stat{background:var(--paper);border:1px solid var(--line);border-radius:12px;padding:10px 12px}
  .stat .n{font-family:'Fraunces',serif;font-weight:500;font-size:20px;color:var(--accent-deep);
    letter-spacing:-.02em;line-height:1;display:block}
  .stat .lbl{font-size:10px;text-transform:uppercase;letter-spacing:.12em;
    color:var(--muted);font-weight:700;margin-top:4px;display:block}

  main{max-width:1280px;margin:0 auto;padding:24px 20px 24px;
    display:grid;grid-template-columns:260px 1fr;gap:24px;align-items:start}
  @media (max-width:980px){main{grid-template-columns:1fr;padding:16px 12px 24px;gap:14px}}

  /* FILTERS SIDEBAR */
  aside.filters{position:sticky;top:60px;background:var(--paper);border:1px solid var(--line);
    border-radius:16px;padding:16px 16px;box-shadow:var(--shadow-sm);
    max-height:calc(100vh - 90px);overflow-y:auto}
  aside.filters h3{font-family:'Fraunces',serif;font-weight:500;font-size:15px;margin:0 0 10px;
    color:var(--ink);display:flex;justify-content:space-between;align-items:center;gap:8px}
  aside.filters h3 .actions{display:flex;gap:10px;align-items:center}
  aside.filters h3 button.reset{font-size:10.5px;color:var(--accent-deep);background:none;border:none;
    cursor:pointer;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:3px 6px;border-radius:6px}
  aside.filters h3 button.reset:hover{background:var(--accent-soft)}
  aside.filters .close-drawer{display:none;background:var(--warm);border:1px solid var(--line);border-radius:8px;
    width:32px;height:32px;align-items:center;justify-content:center;cursor:pointer;font-size:16px;color:var(--ink-soft);padding:0}

  .fgroup{margin-bottom:14px;padding-bottom:12px;border-bottom:1px dashed var(--line-soft)}
  .fgroup:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
  .fgroup .glbl{font-size:10px;text-transform:uppercase;letter-spacing:.14em;color:var(--muted);
    font-weight:700;margin-bottom:6px;display:block}
  .fopt{display:flex;align-items:center;gap:8px;padding:5px 0;font-size:13px;color:var(--ink-soft);
    cursor:pointer;user-select:none;min-height:26px}
  .fopt input{margin:0;accent-color:var(--accent-deep);width:15px;height:15px;flex-shrink:0}
  .fopt .n{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--muted)}
  .fopt:hover{color:var(--ink)}
  .swatch{width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0}
  .swatch.risultati{background:var(--green)}
  .swatch.comunicato{background:var(--blue)}
  .swatch.intervista-ceo{background:var(--gold)}
  .swatch.operazione-straordinaria{background:var(--accent)}
  .swatch.fisco{background:var(--plum)}

  /* PERIODO */
  .periodo-presets{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:8px}
  .ppill{font-size:11px;padding:4px 9px;border-radius:999px;background:var(--warm);color:var(--ink-soft);
    font-weight:600;border:1px solid var(--line);cursor:pointer;font-family:inherit;line-height:1.1}
  .ppill:hover{border-color:var(--accent)}
  .ppill.on{background:var(--accent-deep);color:#fdfcf7;border-color:var(--accent-deep)}
  .periodo-slider input[type="range"]{width:100%;accent-color:var(--accent-deep);margin:6px 0 2px;height:20px;cursor:pointer}
  .periodo-label{font-size:11px;color:var(--muted);display:flex;justify-content:space-between;gap:8px;flex-wrap:wrap}
  .periodo-label b{font-family:'Fraunces',serif;font-weight:500;color:var(--ink);font-size:12.5px}
  .periodo-label .ft{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted)}

  /* CLIENT SEARCH */
  .clisearch{display:flex;align-items:center;gap:6px;background:var(--warm);border:1px solid var(--line);
    border-radius:8px;padding:5px 9px;margin-bottom:5px}
  .clisearch::before{content:"⌕";color:var(--muted);font-size:13px;line-height:1}
  .clisearch input{border:none;background:transparent;outline:none;font-size:12.5px;width:100%;color:var(--ink);font-family:inherit}

  details.fascia{margin-top:6px;border-radius:8px;background:var(--warm);border:1px solid var(--line-soft);padding:5px 9px 6px}
  details.fascia > summary{cursor:pointer;font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:var(--ink-soft);
    font-weight:700;padding:5px 0;display:flex;align-items:center;gap:6px;list-style:none;outline:none}
  details.fascia > summary::-webkit-details-marker{display:none}
  details.fascia > summary::before{content:"▸";color:var(--muted);font-size:9px;transition:transform .12s ease;display:inline-block}
  details.fascia[open] > summary::before{transform:rotate(90deg)}
  details.fascia > summary .badge-mini{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted);font-weight:600}
  details.fascia .fopt{padding:4px 0;font-size:12px;min-height:22px}

  /* MOBILE DRAWER */
  .filter-fab{display:none}
  .filter-backdrop{display:none}
  @media (max-width:980px){
    aside.filters{position:fixed;top:0;left:0;right:0;bottom:0;border-radius:0;max-height:100vh;
      transform:translateX(-100%);transition:transform .26s ease;z-index:60;padding:16px 16px 90px;border:none;border-right:1px solid var(--line)}
    aside.filters.open{transform:translateX(0);box-shadow:var(--shadow-lg)}
    aside.filters .close-drawer{display:inline-flex}
    .filter-backdrop{display:block;position:fixed;inset:0;background:rgba(31,30,28,.42);
      opacity:0;pointer-events:none;transition:opacity .22s ease;z-index:55}
    .filter-backdrop.on{opacity:1;pointer-events:auto}
    .filter-fab{display:inline-flex;position:fixed;bottom:16px;left:50%;transform:translateX(-50%);
      z-index:50;background:var(--ink);color:#fdfcf7;border:none;border-radius:999px;
      padding:12px 22px;font-size:13.5px;font-weight:600;align-items:center;gap:8px;
      box-shadow:0 10px 30px -8px rgba(31,30,28,.4), 0 4px 12px rgba(31,30,28,.18);cursor:pointer}
    .filter-fab .count{background:var(--accent);color:#fdfcf7;font-family:'JetBrains Mono',monospace;
      font-size:10.5px;font-weight:700;border-radius:999px;padding:2px 7px;min-width:20px;text-align:center;display:none}
    .filter-fab .count.on{display:inline-block}
  }
  @media (max-width:540px){.filter-fab{left:14px;right:14px;transform:none;justify-content:center}}

  /* STREAM */
  .stream-head{display:flex;align-items:baseline;justify-content:space-between;gap:12px;margin-bottom:10px;flex-wrap:wrap}
  .stream-head h2{font-family:'Fraunces',serif;font-weight:500;font-size:18px;margin:0;color:var(--ink);letter-spacing:-.01em}
  .stream-head .count{font-size:12px;color:var(--muted);font-family:'JetBrains Mono',monospace}

  .stream{display:flex;flex-direction:column;gap:12px}
  article.card{background:var(--paper);border:1px solid var(--line);border-radius:14px;
    padding:16px 18px;box-shadow:var(--shadow-sm);display:flex;flex-direction:column;gap:8px;
    position:relative;overflow:hidden;transition:box-shadow .15s}
  @media (max-width:560px){article.card{padding:14px 16px;border-radius:12px}}
  article.card:hover{box-shadow:var(--shadow-md)}
  article.card::before{content:"";position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--line)}
  article.card[data-tipo="risultati"]::before{background:var(--green)}
  article.card[data-tipo="comunicato"]::before{background:var(--blue)}
  article.card[data-tipo="intervista-ceo"]::before{background:var(--gold)}
  article.card[data-tipo="operazione-straordinaria"]::before{background:var(--accent)}
  article.card[data-tipo="fisco"]::before{background:var(--plum)}

  article.card .meta-row{display:flex;align-items:center;gap:8px;font-size:10.5px;color:var(--muted);
    text-transform:uppercase;letter-spacing:.1em;font-weight:600;flex-wrap:wrap}
  article.card .meta-row time{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--accent-deep)}
  article.card .meta-row .src{color:var(--ink-soft)}
  article.card .meta-row .dotsep{width:3px;height:3px;border-radius:50%;background:var(--line);display:inline-block;flex-shrink:0}

  /* CLIENT PILL — CLICCABILE */
  .client-pill{display:inline-flex;align-items:center;gap:6px;font-size:11px;padding:3px 9px 3px 7px;
    border-radius:999px;font-weight:700;letter-spacing:.02em;text-transform:none;
    background:var(--warm);color:var(--ink-soft);border:1px solid var(--line);cursor:pointer;
    transition:transform .12s, box-shadow .12s;font-family:inherit}
  .client-pill:hover{transform:translateY(-1px);box-shadow:0 2px 6px rgba(31,30,28,.1)}
  .client-pill:active{transform:translateY(0)}
  .client-pill::before{content:"";width:6px;height:6px;border-radius:50%;flex-shrink:0;background:var(--muted)}
  .client-pill.f-top10{background:var(--accent-soft);color:var(--accent-deep);border-color:#f0d4c5}
  .client-pill.f-top10::before{background:var(--accent)}
  .client-pill.f-media{background:var(--gold-soft);color:#7a6320;border-color:#e6d390}
  .client-pill.f-media::before{background:var(--gold)}
  .client-pill.f-piccola{background:var(--green-soft);color:#3e6a4d;border-color:#bcd4c2}
  .client-pill.f-piccola::before{background:var(--green)}
  .client-pill::after{content:"›";font-weight:400;opacity:.5;font-size:14px;line-height:1;margin-left:2px}

  article.card h3{font-family:'Fraunces',serif;font-weight:500;font-size:18px;line-height:1.25;
    letter-spacing:-.01em;margin:2px 0 0;color:var(--ink)}
  @media (max-width:560px){article.card h3{font-size:16.5px}}
  article.card p.sum{font-size:13.5px;color:var(--ink-soft);line-height:1.55;margin:0}
  article.card .detail{font-size:12px;color:var(--muted);line-height:1.5;margin:0;padding:8px 12px;
    background:var(--warm);border-radius:8px;border-left:2px solid var(--line)}
  article.card .audit-alert{font-size:11px;font-weight:700;letter-spacing:.06em;color:#a85a40;
    background:var(--gold-soft);border:1px solid #e6d390;border-radius:6px;padding:5px 10px;text-transform:uppercase}
  article.card .foot{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-top:auto;padding-top:4px;flex-wrap:wrap}
  article.card .foot a.read{font-size:12px;font-weight:600;color:var(--accent-deep)}
  .tag{font-size:10px;padding:3px 9px;border-radius:999px;font-weight:700;
    text-transform:uppercase;letter-spacing:.06em;border:1px solid;flex-shrink:0}
  .tag.t-risultati{background:var(--green-soft);color:#3e6a4d;border-color:#bcd4c2}
  .tag.t-comunicato{background:var(--blue-soft);color:#3d5874;border-color:#bccad8}
  .tag.t-intervista-ceo{background:var(--gold-soft);color:#7a6320;border-color:#e6d390}
  .tag.t-operazione-straordinaria{background:var(--accent-soft);color:var(--accent-deep);border-color:#f0d4c5}
  .tag.t-fisco{background:var(--plum-soft);color:var(--plum);border-color:#dcc1d4}

  .empty{padding:36px 20px;text-align:center;color:var(--muted);font-size:14px;
    background:var(--paper);border:1px dashed var(--line);border-radius:12px}

  /* BANK MODAL */
  .modal-backdrop{position:fixed;inset:0;background:rgba(31,30,28,.45);opacity:0;pointer-events:none;
    transition:opacity .2s ease;z-index:80}
  .modal-backdrop.on{opacity:1;pointer-events:auto}
  .bank-modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(.96);
    background:var(--paper);border:1px solid var(--line);border-radius:20px;box-shadow:var(--shadow-lg);
    width:calc(100% - 32px);max-width:560px;max-height:calc(100vh - 40px);overflow-y:auto;z-index:90;
    opacity:0;pointer-events:none;transition:opacity .18s ease, transform .18s ease}
  .bank-modal.on{opacity:1;pointer-events:auto;transform:translate(-50%,-50%) scale(1)}
  .bank-modal .modal-body{padding:26px 28px}
  @media (max-width:560px){.bank-modal{border-radius:16px}.bank-modal .modal-body{padding:20px 20px}}
  .bank-modal .modal-close{position:absolute;top:16px;right:16px;background:var(--warm);
    border:1px solid var(--line);border-radius:10px;width:34px;height:34px;font-size:16px;
    color:var(--ink-soft);cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0}
  .bank-modal .modal-close:hover{background:var(--accent-soft);color:var(--accent-deep)}
  .bank-modal h2{font-family:'Fraunces',serif;font-weight:500;font-size:24px;margin:0 0 4px;
    letter-spacing:-.015em;color:var(--ink);padding-right:40px}
  .bank-modal .modal-badge{display:inline-block;font-size:10.5px;text-transform:uppercase;letter-spacing:.14em;
    font-weight:700;padding:4px 10px;border-radius:999px;margin-bottom:14px}
  .bank-modal .modal-badge.top10{background:var(--accent-soft);color:var(--accent-deep)}
  .bank-modal .modal-badge.media{background:var(--gold-soft);color:#7a6320}
  .bank-modal .modal-badge.piccola{background:var(--green-soft);color:#3e6a4d}
  .bank-modal dl{margin:0;display:grid;grid-template-columns:1fr;gap:0}
  .bank-modal dl > div{display:grid;grid-template-columns:130px 1fr;gap:12px;padding:9px 0;border-bottom:1px dashed var(--line-soft);align-items:baseline}
  @media (max-width:520px){.bank-modal dl > div{grid-template-columns:110px 1fr;gap:8px;padding:8px 0}}
  .bank-modal dl > div:last-child{border-bottom:none}
  .bank-modal dt{font-size:10.5px;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);font-weight:700}
  .bank-modal dd{font-family:'Fraunces',serif;font-weight:500;font-size:14.5px;color:var(--ink);margin:0;letter-spacing:-.01em}
  .bank-modal dd.na{font-family:'Inter',sans-serif;color:var(--muted);font-style:italic;font-weight:400;font-size:13px}
  .bank-modal .modal-news-count{margin-top:18px;padding:12px 14px;background:var(--warm);border-radius:10px;
    font-size:12.5px;color:var(--ink-soft);display:flex;justify-content:space-between;align-items:center;gap:10px}
  .bank-modal .modal-news-count b{font-family:'Fraunces',serif;font-weight:500;color:var(--accent-deep);font-size:16px}

  footer{padding:32px 20px 60px;text-align:center;color:var(--muted);font-size:12.5px;
    border-top:1px solid var(--line);margin-top:24px;background:#fdfcf7}
  footer .row{max-width:1280px;margin:0 auto;display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px}
</style>
</head>
<body>

<nav class="top">
  <div class="wrap">
    <div class="brand">
      <span class="dot" aria-hidden="true"></span>
      <div>News banche<br><small>Aggiornato {{ generated_at | fmt_date_long }}</small></div>
    </div>
    <ul>
      <li><a href="index.html">← Home</a></li>
    </ul>
  </div>
</nav>

<header class="hero">
  <div class="wrap">
    <span class="eyebrow">Settimanale · prossimo update {{ next_update | fmt_date_long }}</span>
    <h1>Intelligence <em>banche italiane</em></h1>
    <p class="lead">Notizie in ordine cronologico decrescente. Clicca sul nome di una banca per aprire la scheda anagrafica con revisore, governance e dati finanziari.</p>
    <div class="stats-row">
      <div class="stat"><span class="n">{{ n_items }}</span><span class="lbl">news</span></div>
      <div class="stat"><span class="n">{{ n_fonti }}</span><span class="lbl">fonti</span></div>
      <div class="stat"><span class="n">{{ n_banche_monitorate }}</span><span class="lbl">banche</span></div>
      <div class="stat"><span class="n">{{ n_clienti_con_news }}</span><span class="lbl">con news</span></div>
    </div>
  </div>
</header>

<div class="filter-backdrop" id="filterBackdrop"></div>

<main>
  <aside class="filters" id="filtersPanel" aria-label="Filtri">
    <h3>Filtri
      <span class="actions">
        <button type="button" class="reset" id="resetBtn">Azzera</button>
        <button type="button" class="close-drawer" id="closeDrawer" aria-label="Chiudi">✕</button>
      </span>
    </h3>

    <div class="fgroup">
      <span class="glbl">Periodo</span>
      <div class="periodo-presets">
        <button type="button" class="ppill" data-days="7">7 gg</button>
        <button type="button" class="ppill" data-days="30">30 gg</button>
        <button type="button" class="ppill" data-days="90">3 mesi</button>
        <button type="button" class="ppill on" data-days="365">Tutto</button>
      </div>
      <div class="periodo-slider">
        <input type="range" id="dateRange" min="7" max="365" step="1" value="365" aria-label="Ultimi N giorni">
        <div class="periodo-label"><span>Ultimi <b id="dateRangeLabel">∞</b> giorni</span><span class="ft" id="dateRangeFromTo">tutte le news</span></div>
      </div>
    </div>

    <div class="fgroup">
      <span class="glbl">Tipologia</span>
      {% for slug, label in [('risultati','Risultati'),('comunicato','Comunicati'),('intervista-ceo','Interviste CEO'),('operazione-straordinaria','Operaz. straord.'),('fisco','Fisco')] %}
      <label class="fopt"><input type="checkbox" data-filter="tipo" data-val="{{ slug }}"> <span class="swatch {{ slug }}"></span> {{ label }} <span class="n">{{ counters.tipo.get(slug, 0) }}</span></label>
      {% endfor %}
    </div>

    <div class="fgroup">
      <span class="glbl">Fascia</span>
      {% for slug, label in [('top10','Top 10 gruppi'),('media','Medie / regionali'),('piccola','Piccole / fintech')] %}
      <label class="fopt"><input type="checkbox" data-filter="fascia" data-val="{{ slug }}"> {{ label }} <span class="n">{{ counters.fascia.get(slug, 0) }}</span></label>
      {% endfor %}
    </div>

    <div class="fgroup">
      <span class="glbl">Cliente ({{ n_banche_monitorate }} banche)</span>
      <div class="clisearch"><input type="search" id="clisearch" placeholder="Cerca banca…" autocomplete="off"></div>
      {% for fkey, flabel in [('top10','Top 10 gruppi'),('media','Banche medie'),('piccola','Piccole / fintech')] %}
      <details class="fascia" open>
        <summary>{{ flabel }} <span class="badge-mini">{{ by_fascia[fkey] | length }}</span></summary>
        {% for c in by_fascia[fkey] %}
        <label class="fopt"><input type="checkbox" data-filter="cliente" data-val="{{ c.slug }}"> {{ c.nome }} <span class="n">{{ counters.cliente.get(c.slug, 0) }}</span></label>
        {% endfor %}
      </details>
      {% endfor %}
    </div>

    <div class="fgroup">
      <span class="glbl">Emittente</span>
      {% for slug, label in [('sole24','Il Sole 24 Ore'),('ansa','ANSA'),('mf','MF Milano Finanza'),('bloomberg','Bloomberg'),('reuters','Reuters'),('corporate','Corporate press'),('bebeez','BeBeez'),('eutekne','Eutekne'),('fiscooggi','FiscoOggi'),('bancaditalia',"Banca d'Italia"),('cittadinomb','Il Cittadino MB'),('altro','Altro')] %}
      <label class="fopt"><input type="checkbox" data-filter="emittente" data-val="{{ slug }}"> {{ label }} {% if counters.emittente.get(slug, 0) > 0 %}<span class="n">{{ counters.emittente.get(slug, 0) }}</span>{% endif %}</label>
      {% endfor %}
    </div>
  </aside>

  <section class="content">
    <div class="stream-head">
      <h2>Ultime news</h2>
      <span class="count"><b id="cntVis">{{ n_items }}</b> di {{ n_items }} · cronologico decrescente</span>
    </div>
    <div class="stream" id="stream">
      {% for item in items_sorted %}
      {% set banca = banche_dict.get(item.cliente_slug) %}
      <article class="card" data-cliente="{{ item.cliente_slug }}" data-fascia="{{ item.fascia }}" data-emittente="{{ item.emittente_slug }}" data-tipo="{{ item.tipo }}" data-date="{{ item.data }}">
        <div class="meta-row">
          <button type="button" class="client-pill f-{{ item.fascia }}" onclick="openBank('{{ item.cliente_slug }}')">{{ banca.nome if banca else item.cliente_slug }}</button>
          <time>{{ item.data | fmt_date_short }}</time><span class="dotsep"></span><span class="src">{{ item.emittente_label }}</span>
        </div>
        <h3>{{ item.titolo }}</h3>
        <p class="sum">{{ item.sintesi }}</p>
        {% if item.dettaglio %}<p class="detail">{{ item.dettaglio }}</p>{% endif %}
        {% if item.audit_alert %}<p class="audit-alert">⚠ Audit alert — possibile variazione incarico revisione</p>{% endif %}
        <div class="foot">
          <span class="tag t-{{ item.tipo }}">{% if item.tipo == 'risultati' %}Risultati{% elif item.tipo == 'comunicato' %}Comunicato{% elif item.tipo == 'intervista-ceo' %}Intervista CEO{% elif item.tipo == 'operazione-straordinaria' %}Operaz. straord.{% elif item.tipo == 'fisco' %}Fisco{% else %}{{ item.tipo }}{% endif %}</span>
          {% if item.url %}<a class="read" href="{{ item.url }}" target="_blank" rel="noopener">leggi la fonte →</a>{% endif %}
        </div>
      </article>
      {% else %}
      <div class="empty">Nessuna news raccolta in questo run.</div>
      {% endfor %}
    </div>
    <div class="empty" id="emptyState" style="display:none">Nessuna news corrisponde ai filtri. <a href="#" id="emptyReset">Azzera</a>.</div>
  </section>
</main>

<button class="filter-fab" id="filterFab" type="button" aria-label="Filtri">
  <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M2 3.5h12M4 8h8M6 12.5h4"/></svg>
  <span>Filtri</span>
  <span class="count" id="filterCount">0</span>
</button>

<!-- MODAL BANCA -->
<div class="modal-backdrop" id="modalBackdrop" onclick="closeBank()"></div>
<aside class="bank-modal" id="bankModal" aria-hidden="true" role="dialog">
  <button type="button" class="modal-close" onclick="closeBank()" aria-label="Chiudi">✕</button>
  <div class="modal-body" id="modalBody"></div>
</aside>

<footer>
  <div class="row">
    <div>Aggiornamento News Banche · generato {{ generated_at | fmt_date_long }}</div>
    <div>Sintesi assistita da AI · verifica sempre le fonti</div>
  </div>
</footer>

<script>
const BANCHE = {{ banche_dict | tojson }};
const NEWS_COUNT_BY_CLIENT = {{ counters.cliente | tojson }};

(function(){
  var active = { cliente:[], fascia:[], emittente:[], tipo:[] };
  var TODAY = new Date({{ generated_at.year }}, {{ generated_at.month - 1 }}, {{ generated_at.day }});
  var maxDays = 365;

  var checks = document.querySelectorAll('input[type="checkbox"][data-filter]');
  var panel = document.getElementById('filtersPanel');
  var backdrop = document.getElementById('filterBackdrop');
  var fab = document.getElementById('filterFab');
  var fabCount = document.getElementById('filterCount');
  var closeBtn = document.getElementById('closeDrawer');
  var resetBtn = document.getElementById('resetBtn');
  var search = document.getElementById('clisearch');
  var dateRange = document.getElementById('dateRange');
  var dateRangeLabel = document.getElementById('dateRangeLabel');
  var dateRangeFromTo = document.getElementById('dateRangeFromTo');
  var presets = document.querySelectorAll('.ppill');

  var MM_IT = ['gen','feb','mar','apr','mag','giu','lug','ago','set','ott','nov','dic'];
  function fmtIt(d){ return d.getDate() + ' ' + MM_IT[d.getMonth()] + ' ' + d.getFullYear(); }
  function parseISO(s){ var p = String(s).split('-'); return new Date(+p[0], +p[1]-1, +p[2]); }

  function updateDateUI(days){
    if(days >= 365){ dateRangeLabel.textContent = '∞'; dateRangeFromTo.textContent = 'tutte le news'; }
    else { dateRangeLabel.textContent = days;
      var from = new Date(TODAY); from.setDate(from.getDate() - days);
      dateRangeFromTo.textContent = 'dal ' + fmtIt(from); }
    presets.forEach(function(p){ p.classList.toggle('on', +p.dataset.days === days); });
  }

  if(dateRange) dateRange.addEventListener('input', function(){ maxDays = +this.value; updateDateUI(maxDays); apply(); });
  presets.forEach(function(p){ p.addEventListener('click', function(){ maxDays = +p.dataset.days;
    if(dateRange) dateRange.value = maxDays; updateDateUI(maxDays); apply(); }); });

  checks.forEach(function(c){ c.addEventListener('change', function(){
    var f = c.dataset.filter, v = c.dataset.val;
    var i = active[f].indexOf(v);
    if(c.checked && i<0) active[f].push(v);
    else if(!c.checked && i>=0) active[f].splice(i,1);
    apply();
  }); });

  if(resetBtn) resetBtn.addEventListener('click', reset);
  var er = document.getElementById('emptyReset'); if(er) er.addEventListener('click', function(e){e.preventDefault(); reset();});

  if(fab) fab.addEventListener('click', openDrawer);
  if(closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if(backdrop) backdrop.addEventListener('click', closeDrawer);

  function openDrawer(){ panel.classList.add('open'); backdrop.classList.add('on'); document.body.style.overflow='hidden'; }
  function closeDrawer(){ panel.classList.remove('open'); backdrop.classList.remove('on'); document.body.style.overflow=''; }

  document.querySelectorAll('article.card a.read').forEach(function(a){
    a.addEventListener('click', function(){ if(window.innerWidth<=980) closeDrawer(); });
  });

  if(search) search.addEventListener('input', function(){
    var q = search.value.trim().toLowerCase();
    document.querySelectorAll('details.fascia .fopt').forEach(function(opt){
      var label = opt.textContent.trim().toLowerCase();
      opt.style.display = (q==='' || label.indexOf(q)>=0) ? '' : 'none';
    });
    if(q!=='') document.querySelectorAll('details.fascia').forEach(function(d){ d.open = true; });
  });

  function reset(){
    Object.keys(active).forEach(function(k){ active[k]=[]; });
    checks.forEach(function(c){ c.checked=false; });
    if(search){ search.value=''; document.querySelectorAll('details.fascia .fopt').forEach(function(o){o.style.display='';}); }
    maxDays = 365; if(dateRange) dateRange.value = 365; updateDateUI(365);
    apply();
  }

  function apply(){
    var cards = document.querySelectorAll('article.card');
    var visible = 0;
    cards.forEach(function(c){
      var ok = true;
      Object.keys(active).forEach(function(k){
        if(active[k].length && active[k].indexOf(c.dataset[k]) < 0) ok = false;
      });
      if(ok && maxDays < 365 && c.dataset.date){
        var d = parseISO(c.dataset.date);
        var ageDays = Math.floor((TODAY - d) / 86400000);
        if(ageDays > maxDays) ok = false;
      }
      c.style.display = ok ? '' : 'none';
      if(ok) visible++;
    });
    var emptyState = document.getElementById('emptyState');
    if(emptyState) emptyState.style.display = visible ? 'none' : '';
    var cntVis = document.getElementById('cntVis');
    if(cntVis) cntVis.textContent = visible;

    var total = active.cliente.length + active.fascia.length + active.emittente.length + active.tipo.length;
    if(maxDays < 365) total++;
    if(fabCount){ fabCount.textContent = total; fabCount.classList.toggle('on', total>0); }
  }

  updateDateUI(365);
  apply();
})();

// === MODAL BANCA ===
function openBank(slug){
  var b = BANCHE[slug];
  if(!b) return;
  var body = document.getElementById('modalBody');
  var newsN = NEWS_COUNT_BY_CLIENT[slug] || 0;
  var fasciaLbl = b.fascia === 'top10' ? 'Top 10 gruppi' : (b.fascia === 'media' ? 'Banca media' : 'Piccola / fintech');
  function row(lbl, val, unit){
    if(val === null || val === undefined || val === '') return '<div><dt>'+lbl+'</dt><dd class="na">— non disponibile</dd></div>';
    return '<div><dt>'+lbl+'</dt><dd>'+val+(unit?' '+unit:'')+'</dd></div>';
  }
  body.innerHTML =
    '<h2>'+b.nome+'</h2>' +
    '<span class="modal-badge '+b.fascia+'">'+fasciaLbl+'</span>' +
    '<dl>' +
      row('Revisore', b.revisore) +
      row('Ult. esercizio', b.ultimo_esercizio_revisionato) +
      row('Incarico fino al', b.incarico_fino_al) +
      row('Amministratore Delegato', b.ad) +
      row('Presidente', b.presidente) +
      row('Dipendenti', b.dipendenti) +
      row('Totale attivo', b.totale_attivo_mln_eur, 'mln €') +
      row('Utile ultimo esercizio', b.utile_ultimo_esercizio_mln_eur, 'mln €') +
      (b.esercizio_riferimento ? row('Esercizio riferimento dati fin.', b.esercizio_riferimento) : '') +
    '</dl>' +
    '<div class="modal-news-count"><span>News in dashboard per '+b.nome.split(' ')[0]+'</span><b>'+newsN+'</b></div>';
  document.getElementById('bankModal').classList.add('on');
  document.getElementById('modalBackdrop').classList.add('on');
  document.getElementById('bankModal').setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
}
function closeBank(){
  document.getElementById('bankModal').classList.remove('on');
  document.getElementById('modalBackdrop').classList.remove('on');
  document.getElementById('bankModal').setAttribute('aria-hidden', 'true');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e){ if(e.key === 'Escape') closeBank(); });
</script>

</body>
</html>
